# ==============================================================================
# SECURED NETWORKS LLC - MULTI-ZONE UNIFIED FLEET DEPLOYMENT
# Target File: proxmox-support-plane/ansible/deploy-fleet.yml
# Reference: ATT_Source_of_Truth_v5_24.3
# Compliance: NIST SP 800-53 Rev 5 (CM-2, CM-8 Baseline Configuration)
# ==============================================================================
---
- name: Phase 1 - Hypervisor Optimization & Declarative SDN Mesh Setup
  hosts: proxmox_hosts
  gather_facts: false
  vars:
    ansible_python_interpreter: auto_silent
  tasks:
    - name: Enforce Host-Level Swappiness for Failsafe Memory Oversubscription
      ansible.posix.sysctl:
        name: vm.swappiness
        value: '10'
        state: present
        reload: true

    - name: Initialize SDN Local Zone Core Configuration
      ansible.builtin.command: >
        pvesh create /cluster/sdn/zones 
        --zone localnet 
        --type vlan 
        --bridge vmbr0
      register: sdn_zone_init
      failed_when: false
      changed_when: "'already exists' not in sdn_zone_init.stderr"

    - name: Declare Subnet VNets for Core Blast Radius Microsegmentation
      ansible.builtin.command: >
        pvesh create /cluster/sdn/vnets 
        --vnet {{ item.vnet }} 
        --zone localnet
      register: vnet_creation
      failed_when: false
      changed_when: "'already exists' not in vnet_creation.stderr"
      loop:
        - { vnet: "vnet10" }
        - { vnet: "vnet30" }
        - { vnet: "vnet40" }

    - name: Apply and Commit Network Topology Changes
      ansible.builtin.command: pvesh set /cluster/sdn

- name: Phase 2 - Declarative Support Plane Container Provisioning
  hosts: local_deployer
  gather_facts: false
  vars:
    ansible_python_interpreter: auto_silent
    pve_api_host: "10.0.0.95"
    pve_api_user: "ansible@pam"
    pve_api_token: "provisioner"
    pve_api_secret: "3006abce-ae0c-4307-83c2-23402b58d7b7"
    default_lxc_password: "Sn-Lxc-Admin-2026!"
    storage_pool: "local-zfs"
    os_template: "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"

    lxc_fleet:
      # ZONE 1: MANAGEMENT
      - { name: "sn-dns-unbound", vmid: 103, mem: 256, cores: 1, disk: 2, nesting: false, net: '{"net0":"name=eth0,ip=10.0.0.103/24,bridge=vmbr0,gw=10.0.0.1"}' }
      - { name: "sn-devops-gitea", vmid: 104, mem: 2048, cores: 2, disk: 16, nesting: false, net: '{"net0":"name=eth0,ip=10.0.0.104/24,bridge=vmbr0,gw=10.0.0.1"}' }
      # ZONE 2: EDGE / ACCESS
      - { name: "sn-edge-proxy", vmid: 105, mem: 512, cores: 2, disk: 4, nesting: false, net: '{"net0":"name=eth0,ip=10.0.0.105/24,bridge=vmbr0,gw=10.0.0.1", "net1":"name=eth1,ip=172.16.10.105/24,bridge=vnet10"}' }
      - { name: "sn-auth-authentik", vmid: 106, mem: 2048, cores: 2, disk: 16, nesting: true, net: '{"net0":"name=eth0,ip=10.0.0.106/24,bridge=vmbr0,gw=10.0.0.1", "net1":"name=eth1,ip=172.16.10.106/24,bridge=vnet10"}' }
      - { name: "sn-guacamole-gateway", vmid: 107, mem: 2048, cores: 2, disk: 8, nesting: false, net: '{"net0":"name=eth0,ip=10.0.0.107/24,bridge=vmbr0,gw=10.0.0.1", "net1":"name=eth1,ip=172.16.10.107/24,bridge=vnet10"}' }
      - { name: "sn-tailscale-exit", vmid: 108, mem: 512, cores: 1, disk: 4, nesting: false, net: '{"net0":"name=eth0,ip=10.0.0.108/24,bridge=vmbr0,gw=10.0.0.1", "net1":"name=eth1,ip=172.16.10.108/24,bridge=vnet10"}' }
      # ZONE 3: DATA / SECRETS
      - { name: "att-db-postgres", vmid: 109, mem: 2048, cores: 2, disk: 32, nesting: false, net: '{"net0":"name=eth0,ip=172.16.30.109/24,bridge=vnet30"}' }
      - { name: "att-vault-secrets", vmid: 110, mem: 256, cores: 1, disk: 4, nesting: false, net: '{"net0":"name=eth0,ip=172.16.30.110/24,bridge=vnet30"}' }
      # ZONE 5: OBSERVABILITY
      - { name: "sn-loki-tsdb", vmid: 111, mem: 1536, cores: 2, disk: 32, nesting: false, net: '{"net0":"name=eth0,ip=172.16.40.111/24,bridge=vnet40"}' }
      - { name: "sn-prometheus-metrics", vmid: 112, mem: 1536, cores: 2, disk: 16, nesting: false, net: '{"net0":"name=eth0,ip=172.16.40.112/24,bridge=vnet40"}' }
      - { name: "sn-grafana-ui", vmid: 113, mem: 1024, cores: 2, disk: 8, nesting: false, net: '{"net0":"name=eth0,ip=172.16.40.113/24,bridge=vnet40"}' }

  tasks:
    - name: Provision Multi-Tenant Secure Support Plane via Proxmox REST Engine
      community.proxmox.proxmox:
        api_user: "{{ pve_api_user }}"
        api_token_id: "{{ pve_api_token }}"
        api_token_secret: "{{ pve_api_secret }}"
        api_host: "{{ pve_api_host }}"
        validate_certs: false
        hostname: "{{ item.name }}"
        vmid: "{{ item.vmid }}"
        node: "pve"
        password: "{{ default_lxc_password }}"
        ostemplate: "{{ os_template }}"
        memory: "{{ item.mem }}"
        cores: "{{ item.cores }}"
        storage: "{{ storage_pool }}"
        disk: "{{ item.disk }}"
        netif: "{{ item.net }}"
        unprivileged: true
        features: ["nesting={{ item.nesting | int }}"]
        onboot: true
        state: present
      loop: "{{ lxc_fleet }}"